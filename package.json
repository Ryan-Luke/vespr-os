{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"PORT=3001 npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "electron:build": "electron-builder",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:win": "electron-builder --win",
    "electron:build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.vespr.app",
    "productName": "VESPR",
    "directories": {
      "output": "dist-electron"
    },
    "mac": {
      "category": "public.app-category.business",
      "icon": "public/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ],
      "publisherName": "VESPR Inc"
    },
    "linux": {
      "icon": "public/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "YOUR_GITHUB_ORG",
      "repo": "vespr-os"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/react": "^3.0.147",
    "@base-ui/react": "^1.3.0",
    "@blocknote/core": "^0.47.3",
    "@blocknote/react": "^0.47.3",
    "@blocknote/shadcn": "^0.47.3",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.48.0",
    "@stripe/stripe-js": "^9.1.0",
    "ai": "^6.0.145",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "shadcn": "^4.1.2",
    "stripe": "^22.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "happy-dom": "^20.8.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
